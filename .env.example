# 各 HTTP 服务独立监听地址（gateway/admin/console 可同时启动而不冲突）。
GATEWAY_HTTP_ADDR=:8521
ADMIN_HTTP_ADDR=:8522
CONSOLE_HTTP_ADDR=:8523

# 以下 HTTP 超时为所有服务共享。
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s

# 单个 JSON 请求体上限（单位 MB）；防 OOM / zip bomb 的网关 ingress 安全配置，超限返回 413。
# 默认 128（对齐 new-api 方向，覆盖 Codex 长会话 + tool 大 payload）；本地开发可按需调小。
# 注意：前置代理（如 Nginx client_max_body_size）须 ≥ 此值，否则请求仍会在代理层被 413 拒绝。
HTTP_MAX_JSON_BODY_MB=128

# 日志级别：debug | info | warn | error（大小写不敏感）。
LOG_LEVEL=info
# 日志格式（对齐 zap 官方预设，console 额外开彩色级别 + RFC3339 + " | " 分隔）：
#   console → Development（本地可读）
#   json    → Production + RFC3339 时间（生产/采集）
LOG_FORMAT=console

DATABASE_URL=postgres://unio:unio_dev_password@127.0.0.1:5432/unio?sslmode=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=1
POSTGRES_MAX_CONN_LIFETIME=1h
POSTGRES_MAX_CONN_IDLE_TIME=30m
POSTGRES_HEALTH_CHECK_PERIOD=5s

REDIS_ADDR=127.0.0.1:6380
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_SIZE=10
REDIS_MAX_RETRIES=3
REDIS_MIN_RETRY_BACKOFF=8ms
REDIS_MAX_RETRY_BACKOFF=512ms
REDIS_KEY_NAMESPACE=unio:dev

# 【已迁移到运行时配置】以下 6 组 gateway 热路径配置不再从 env 读取，改为 app_settings 运行时
# 配置（admin 后台「系统 → 运行时配置」管理，写后约 5s 热生效，免重启）：
#   限流全局默认（原 RATE_LIMIT_DEFAULT_RPM/TPM/RPD、RATE_LIMIT_FAILURE_POLICY）
#   熔断器（原 CIRCUIT_BREAKER_*）
#   渠道 429 冷却（原 GATEWAY_CHANNEL_RATELIMIT_COOLDOWN(_CAP)）
#   凭据 401 阈值（原 GATEWAY_CHANNEL_CREDENTIAL_401_THRESHOLD）
#   流式 idle 超时（原 GATEWAY_STREAM_IDLE_TIMEOUT）
#   默认渠道超时（原 30s 硬编码）
# 首次启动自动以代码默认值 seed 入库；详见 docs/production/DESIGN-env-to-runtime-settings-migration.md。

# 无上游真实 usage 的流式 partial 结算（上游流中途报错/客户端 chunks 后取消/缺 final usage）：
# 按此比例把估算输入拆成 cache_read / uncached 计费，取值 [0,1]（0.6 = 60% 缓存 / 40% 未缓存）。
# 临时口径——最优是按历史真实缓存率预估（见 lifecycle/partial_stream.go TODO）。
# 注意：仅当客户售价配置了 cache_read 单价时才真正生效，否则退化为全 uncached。
PARTIAL_ASSUMED_CACHE_READ_RATIO=0.6

# 输入 token 估算的媒体处理（限流预占 / 计费冻结用；只对文本内容跑 tiktoken，图片走 tile 数学）。
# COUNT_MEDIA=false 时图片按固定保守值估算（不解码/不抓取）。
# FETCH_REMOTE_IMAGES=true 时会抓取客户图片 URL 读取真实尺寸——存在 SSRF/延迟风险，默认关闭；
#   内联 base64 图片始终本地解码，不受此开关影响。FETCH_TIMEOUT / FETCH_MAX_MB 限制抓取。
TOKEN_ESTIMATE_COUNT_MEDIA=true
TOKEN_ESTIMATE_FETCH_REMOTE_IMAGES=false
TOKEN_ESTIMATE_FETCH_TIMEOUT=3s
TOKEN_ESTIMATE_FETCH_MAX_MB=8

WORKER_STARTUP_TIMEOUT=5s
WORKER_RUNNER_IDLE_INTERVAL=1s
WORKER_SETTLEMENT_RECOVERY_LOCK_TTL=30s
WORKER_SETTLEMENT_RECOVERY_INITIAL_DELAY=30s
WORKER_SETTLEMENT_RECOVERY_SETTLE_TIMEOUT=10s
WORKER_SETTLEMENT_RECOVERY_MAX_ATTEMPTS=20
WORKER_SETTLEMENT_RECOVERY_BACKOFF_CAP=5m
# P2-5：补偿 worker 单轮批量 claim/处理上限，积压时加快排空（每条仍 SKIP LOCKED 独立 claim，可与多副本并存）。
WORKER_SETTLEMENT_RECOVERY_BATCH_SIZE=16

# models.dev 模型目录同步（阶段 12/14）：周期性拉取 models.dev 补齐模型上下文窗口/价格/能力；默认关闭（opt-in）。
# 上线前需确认 license/运营签字（GAP-12-011）。MAX_RESPONSE_BYTES 防超大响应 OOM（默认 16MB）。
MODEL_CATALOG_SYNC_ENABLED=false
MODEL_CATALOG_SYNC_INTERVAL=24h
MODEL_CATALOG_SYNC_HTTP_TIMEOUT=30s
MODEL_CATALOG_SYNC_MAX_RESPONSE_BYTES=16777216
MODEL_CATALOG_SYNC_BASE_URL=https://models.dev

# 渠道凭据自动检测 worker（阶段二）。
# 开关 / 巡检间隔 / 探测超时 / 日志保留均已聚合到运行时配置（系统设置 → 运营判定）：
#   admin_backend.channel_test
#     enabled / interval_ms（默认 30m）/ probe_timeout_ms（默认 60s）/ log_retention_per_channel（默认 200）
# 探测与用户请求的渠道超时无关；worker 始终注册，可由系统设置热关停。

# 注：渠道上游凭据已改为明文存储（产品决策），不再需要 CREDENTIAL_MASTER_KEY。

ADMIN_API_TOKEN=
# gateway 内部运维端点（熔断快照）。gateway 与 admin 共用同一 token：
#   - gateway：非空则挂载 GET /internal/v1/circuit-breaker
#   - admin：非空则在渠道列表挂载熔断徽章
# GATEWAY_INTERNAL_URLS 默认空；若只配了 token 且 GATEWAY_HTTP_ADDR 为 ":port"，
# admin 会默认请求 http://127.0.0.1:port。多实例时显式写逗号分隔基址。
GATEWAY_INTERNAL_TOKEN=
# GATEWAY_INTERNAL_URLS=http://127.0.0.1:8520
# GATEWAY_INSTANCE_ID=gw-1
