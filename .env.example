HTTP_ADDR=:8520
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s

LOG_LEVEL=INFO

DATABASE_URL=postgres://unio:unio_dev_password@localhost:5432/unio?sslmode=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=1
POSTGRES_MAX_CONN_LIFETIME=1h
POSTGRES_MAX_CONN_IDLE_TIME=30m
POSTGRES_HEALTH_CHECK_PERIOD=5s

REDIS_ADDR=localhost:6380
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_SIZE=10
REDIS_MAX_RETRIES=3
REDIS_MIN_RETRY_BACKOFF=8ms
REDIS_MAX_RETRY_BACKOFF=512ms
REDIS_KEY_NAMESPACE=unio:dev

RATE_LIMIT_DEFAULT_LIMIT=60
RATE_LIMIT_DEFAULT_WINDOW=1m
RATE_LIMIT_FAILURE_POLICY=fail_closed

WORKER_STARTUP_TIMEOUT=5s
WORKER_RUNNER_IDLE_INTERVAL=1s
WORKER_SETTLEMENT_RECOVERY_LOCK_TTL=30s
WORKER_SETTLEMENT_RECOVERY_INITIAL_DELAY=30s
WORKER_SETTLEMENT_RECOVERY_SETTLE_TIMEOUT=10s

# AES-256-GCM master key（base64 编码的 32 随机字节）；用于解密 channels.credential_encrypted
# 生成示例：openssl rand -base64 32
CREDENTIAL_MASTER_KEY=