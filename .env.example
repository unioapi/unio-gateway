# 各 HTTP 服务独立监听地址（gateway/admin/console 可同时启动而不冲突）。
GATEWAY_HTTP_ADDR=:8521
ADMIN_HTTP_ADDR=:8522
CONSOLE_HTTP_ADDR=:8523

# 以下 HTTP 超时为所有服务共享。
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s

# 单个 JSON 请求体上限（单位 MB）；防 OOM / zip bomb 的网关 ingress 安全配置，超限返回 413。
# 默认 128（对齐 new-api 方向，覆盖 Codex 长会话 + tool 大 payload）；本地开发可按需调小。
# 注意：前置代理（如 Nginx client_max_body_size）须 ≥ 此值，否则请求仍会在代理层被 413 拒绝。
HTTP_MAX_JSON_BODY_MB=128

LOG_LEVEL=INFO

DATABASE_URL=postgres://unio:unio_dev_password@127.0.0.1:5432/unio?sslmode=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=1
POSTGRES_MAX_CONN_LIFETIME=1h
POSTGRES_MAX_CONN_IDLE_TIME=30m
POSTGRES_HEALTH_CHECK_PERIOD=5s

REDIS_ADDR=127.0.0.1:6380
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_SIZE=10
REDIS_MAX_RETRIES=3
REDIS_MIN_RETRY_BACKOFF=8ms
REDIS_MAX_RETRY_BACKOFF=512ms
REDIS_KEY_NAMESPACE=unio:dev

# 两层限流（P2-8）全局默认上限：0 表示该维度默认不限；可在 API Key / channel 上单独覆盖。
# RPM=每分钟请求数，TPM=每分钟 token 数，RPD=每日请求数。
RATE_LIMIT_DEFAULT_RPM=60
RATE_LIMIT_DEFAULT_TPM=0
RATE_LIMIT_DEFAULT_RPD=0
RATE_LIMIT_FAILURE_POLICY=fail_closed

# 渠道级 429 冷却（P2-7）：上游返回 429 时按 Retry-After 把该渠道限时踢出 fallback；冷却到期自动恢复。
# COOLDOWN 为无 Retry-After 时的默认冷却（0=该情形不冷却，仅熔断器兜底）；
# COOLDOWN_CAP 为对 Retry-After 建议值的封顶保护（0=不额外封顶）。
GATEWAY_CHANNEL_RATELIMIT_COOLDOWN=5s
GATEWAY_CHANNEL_RATELIMIT_COOLDOWN_CAP=5m

WORKER_STARTUP_TIMEOUT=5s
WORKER_RUNNER_IDLE_INTERVAL=1s
WORKER_SETTLEMENT_RECOVERY_LOCK_TTL=30s
WORKER_SETTLEMENT_RECOVERY_INITIAL_DELAY=30s
WORKER_SETTLEMENT_RECOVERY_SETTLE_TIMEOUT=10s
WORKER_SETTLEMENT_RECOVERY_MAX_ATTEMPTS=20
WORKER_SETTLEMENT_RECOVERY_BACKOFF_CAP=5m
# P2-5：补偿 worker 单轮批量 claim/处理上限，积压时加快排空（每条仍 SKIP LOCKED 独立 claim，可与多副本并存）。
WORKER_SETTLEMENT_RECOVERY_BATCH_SIZE=16

# models.dev 模型目录同步（阶段 12/14）：周期性拉取 models.dev 补齐模型上下文窗口/价格/能力；默认关闭（opt-in）。
# 上线前需确认 license/运营签字（GAP-12-011）。MAX_RESPONSE_BYTES 防超大响应 OOM（默认 16MB）。
MODEL_CATALOG_SYNC_ENABLED=false
MODEL_CATALOG_SYNC_INTERVAL=24h
MODEL_CATALOG_SYNC_HTTP_TIMEOUT=30s
MODEL_CATALOG_SYNC_MAX_RESPONSE_BYTES=16777216
MODEL_CATALOG_SYNC_BASE_URL=https://models.dev

# 注：渠道上游凭据已改为明文存储（产品决策），不再需要 CREDENTIAL_MASTER_KEY。

ADMIN_API_TOKEN=